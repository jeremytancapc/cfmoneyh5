# Copy this file to .env.local for local development.
# Keep secret values in .env.local/.env.stg/.env.production only.

# Environment
NEXT_PUBLIC_APP_ENV=local

# API
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
MYINFO_AUTH_URL=https://4n0hwiuvn0.execute-api.ap-southeast-1.amazonaws.com/stg/auth

# Loan/rate settings (percentage values, e.g. 1.88 = 1.88%)
NEXT_PUBLIC_LOAN_RATE_PERSONAL=1.88
NEXT_PUBLIC_LOAN_RATE_FOREIGNER=2.28
NEXT_PUBLIC_LOAN_RATE_VCSA=1.68

# Optional limits and fees
NEXT_PUBLIC_LOAN_MAX_AMOUNT=50000
NEXT_PUBLIC_LOAN_PROCESSING_FEE=0
