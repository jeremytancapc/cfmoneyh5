# Copy this file to .env.local for local development.
# Keep secret values in .env.local/.env.stg/.env.production only.

# Environment
NEXT_PUBLIC_APP_ENV=local

# API
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
MYINFO_AUTH_URL=https://xxxxxxxxx.execute-api.ap-southeast-1.amazonaws.com/stg/auth

# Session cookie signing key — min 32 chars, keep secret
APPLY_SESSION_SECRET=change-me-to-a-random-32-char-string

# Supabase — https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

AIRCONNECT_API_KEY=
# POST body includes cfh5Id (e.g. CFH5-XXXXXXXX), leadId, loanAmount, customerName, phoneNumber, appointmentDate, timeSlot
AIRCONNECT_APPOINTMENTS_URL=
